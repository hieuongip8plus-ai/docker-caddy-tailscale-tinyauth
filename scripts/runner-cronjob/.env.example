# =============================================================================
# runner-cronjob .env.example — catalog đầy đủ cho CI self-dispatch / cron channels
# =============================================================================
#
# Các biến này dùng cho scripts/runner-cronjob/*.mjs trong GitHub Actions/Azure.
# Không copy biến secret rỗng vào root .env hoặc ENV_FILE. Chỉ đặt key khi có giá trị thật.
# Root .env.example chỉ giữ nhóm tối thiểu; file này là catalog đầy đủ.
#
# Docs:
#   docs/deploys/runner-cronjob.md
#   scripts/runner-cronjob/github-actions.api.md
#   scripts/runner-cronjob/cron-job.org.api.md
#   scripts/runner-cronjob/easycron.api.md
#   scripts/runner-cronjob/webhook.api.md
#   scripts/runner-cronjob/qstash.api.md
#   scripts/runner-cronjob/fastcron.api.md
# =============================================================================

# --- Next run gate ---
# CRONJOB_NEXT_RUN_ENABLE mặc định true nếu không set hoặc rỗng.
# Nhận true/false/1/0/yes/no/on/off.
# CRONJOB_NEXT_RUN_MINUTES là số phút dự kiến của 1 workflow.
# Workflow tự ghi mốc bắt đầu vào ci-logs/runner-cronjob-started-at.txt.
# CRONJOB_NEXT_RUN_ENABLE=true
# CRONJOB_NEXT_RUN_MINUTES=58

# --- GitHub workflow target ---
# Fallback trong GitHub Actions:
#   CRONJOB_OWNER / CRONJOB_REPO ← GITHUB_REPOSITORY
#   CRONJOB_WORKFLOW ← GITHUB_WORKFLOW_REF
#   CRONJOB_REF ← GITHUB_REF_NAME
# CRONJOB_OWNER=your-org
# CRONJOB_ORG=your-org
# CRONJOB_REPO=your-repo
# CRONJOB_WORKFLOW=test.yml
# CRONJOB_REF=main
# CRONJOB_GITHUB_API=https://api.github.com
# CRONJOB_GITHUB_API_VERSION=2022-11-28

# --- Dedupe ---
# run_group phải giống nhau giữa self-dispatch và cron channels để concurrency chặn run song song.
# Nếu bỏ trống trong GitHub Actions: <workflow-name>-<ref-name>.
# CRONJOB_RUN_GROUP=stack-test-main
# CRONJOB_TZ=Asia/Bangkok

# --- Tokens ---
# GitHub Actions self-dispatch dùng GITHUB_TOKEN sẵn có nếu CRONJOB_GITHUB_TOKEN không set.
# Kênh ngoài không có GITHUB_TOKEN, cần fine-grained PAT: Repository permissions → Actions: Read and write.
# CRONJOB_GITHUB_TOKEN=github_pat_or_gh_token
# CRONJOB_DISPATCH_PAT=github_pat_for_external_channels
# CRONJOB_DISPATCH_PAT_AZURE=azure_devops_pat_for_azure_dispatch  # Azure-only PAT; ưu tiên cao nhất khi dispatch vào Azure DevOps
# Fallback chain (GitHub): CRONJOB_DISPATCH_PAT → GITHUB_TOKEN → Azure System.AccessToken → AZURE_DEVOPS_PAT
# Fallback chain (Azure):  CRONJOB_DISPATCH_PAT_AZURE → CRONJOB_DISPATCH_PAT → SYSTEM_ACCESSTOKEN → AZURE_DEVOPS_PAT

# --- Azure DevOps pipeline dispatch ---
# Azure API dùng Basic auth với `:PAT` base64-encoded (tự động trong code). Chỉ cần set raw PAT.
# Org/Project/PipelineId có thể dùng indexed: CRONJOB_AZURE_ORG_1, CRONJOB_AZURE_ORG_2, ...
# Indexed: lấy org từ CRONJOB_AZURE_ORG_<i> (required), các field khác fallback về non-indexed.
# Non-indexed: CRONJOB_AZURE_ORG fallback về ctx.owner khi provider=azure.
# PAT fallback chain: CRONJOB_AZURE_PAT_<i> → CRONJOB_DISPATCH_PAT_AZURE → CRONJOB_DISPATCH_PAT → ...
#
# ⚠️ Khi CRONJOB_AZURE_PIPELINE_ID được set, external cron channels (cron-job.org, EasyCron,
#    FastCron, QStash, webhook) tự động chuyển sang Azure target:
#      - URL: Azure DevOps Pipeline Runs API thay vì GitHub API
#      - Auth: Basic base64(:PAT) thay vì Bearer token
#      - Body: { resources, variables: { CRONJOB_RUN_GROUP, CRONJOB_NEXT_RUN_ENABLE, CRONJOB_NEXT_RUN_MINUTES } }
#      - Tự động cấu hình "Settable at queue time" nếu pipeline chưa có (dùng PAT PATCH API).
#
# --- Non-indexed (single) ---
# CRONJOB_AZURE_ORG=your-org
# CRONJOB_AZURE_PROJECT=your-project
# CRONJOB_AZURE_PIPELINE_ID=123
# CRONJOB_AZURE_API=https://dev.azure.com/{org}/{project}
#
# --- Indexed (multiple pipelines) ---
# Tối đa 20+ pipelines; break khi thiếu CRONJOB_AZURE_ORG_<i>.
# CRONJOB_AZURE_ORG_1=org-alpha
# CRONJOB_AZURE_PROJECT_1=project-alpha
# CRONJOB_AZURE_PIPELINE_ID_1=42
# CRONJOB_AZURE_PAT_1=                          # fallback về CRONJOB_DISPATCH_PAT_AZURE
# CRONJOB_AZURE_HOURS_1=0-6                     # optional, fallback về CRONJOB_HOURS
#
# CRONJOB_AZURE_ORG_2=org-beta
# CRONJOB_AZURE_PROJECT_2=project-beta
# CRONJOB_AZURE_PIPELINE_ID_2=99
# CRONJOB_AZURE_HOURS_2=

# --- cron-job.org channel ---
# Lấy API key: cron-job.org dashboard → Account/API hoặc Settings/API.
# CRONJOB_CRONJOBORG_ENABLE=false          # optional hard-disable; token present normally enables channel
# CRONJOB_CRONJOBORG_API_KEY=cron-job-org-api-key
# CRONJOB_CRONJOBORG_MINUTE=0
# CRONJOB_JOB_TITLE=proxy-stack-keepalive

# --- EasyCron channel ---
# Lấy API key: EasyCron dashboard → API.
# CRONJOB_EASYCRON_ENABLE=false            # optional hard-disable; API key present normally enables channel
# CRONJOB_EASYCRON_API_KEY=easycron-api-key
# CRONJOB_EASYCRON_API=https://api.easycron.com/v1/cron-jobs
# CRONJOB_EASYCRON_CRON=0 * * * *
# CRONJOB_EASYCRON_TIMEOUT=0

# --- FastCron channel ---
# Lấy token: FastCron dashboard → Profile/API.
# CRONJOB_FASTCRON_ENABLE=false            # optional hard-disable; token present normally enables channel
# CRONJOB_FASTCRON_TOKEN=fastcron-api-token
# CRONJOB_FASTCRON_API=https://www.fastcron.com/api/v1/cron_add
# CRONJOB_FASTCRON_EXPRESSION=0 * * * *
# CRONJOB_FASTCRON_TIMEOUT=30

# --- Upstash QStash channel ---
# Lấy token: Upstash Console → QStash.
# CRONJOB_QSTASH_ENABLE=false              # optional hard-disable; token present normally enables channel
# CRONJOB_QSTASH_TOKEN=qstash-token
# CRONJOB_QSTASH_API=https://qstash.upstash.io
# CRONJOB_QSTASH_CRON=0 * * * *
# CRONJOB_QSTASH_SCHEDULE_ID=gh-keepalive-stack-test-main

# --- Generic webhook channel ---
# URL tự host hoặc dịch vụ trung gian nhận payload rồi gọi GitHub dispatch.
# CRONJOB_WEBHOOK_ENABLE=false             # optional hard-disable; URL present normally enables channel
# CRONJOB_WEBHOOK_URL=https://example.com/dispatch
# CRONJOB_WEBHOOK_TOKEN=shared-secret
